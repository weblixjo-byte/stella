Options -MultiViews
RewriteEngine On
RewriteBase /

# Redirect /page.html -> /page (301 permanent, removes .html from URL bar)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# Internally serve /page -> /page.html (so files are found)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^.]+)$ $1.html [NC,L]
